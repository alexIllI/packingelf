# build
desktop-app/build/
host-service/target/
host-service/build-output/
host-data/
host-service/host-data/
dist/
installers/ifw/packages/com.meridian.packingelf.client/data/
installers/ifw/packages/com.meridian.packingelf.host/data/
.tools/
.worktrees/
desktop-app/.qmlls.ini
*.vcxproj*
.vscode/
.qtcreator/
scripts/

# ─── Credentials & secrets (NEVER commit these) ──────────────────────────────
*.enc           # Encrypted account store (accounts.enc)
*.key           # Any raw key files
config.ini      # Legacy config with credentials
secrets.*       # Any secrets file
.env            # Environment variable files with secrets
.env.*
old_version_code/

# ─── Python scraper ───────────────────────────────────────────────────────────
scraper/.venv/          # Virtual environment
scraper/__pycache__/
scraper/src/__pycache__/
scraper/**/__pycache__/
scraper/**/*.pyc
scraper/**/*.pyo
scraper/dist/           # PyInstaller output (scraper.exe)
scraper/build/          # PyInstaller build temp
scraper/*.spec          # PyInstaller spec files (auto-generated)
/scraper/build/
/scraper/*.spec
